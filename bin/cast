const INSPECT_INLINE_LIMIT_BYTES = Number(process.env.CAST_INSPECT_INLINE_LIMIT_BYTES || 750000);
const RUN_SCRIPT_REASON_MAX_WORDS = 6;
const RUN_SCRIPT_REASON_MAX_CHARS = 64;

