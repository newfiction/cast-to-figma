/** Prints usage. */
function usage() {
  console.log(`Cast CLI

Usage:
  cast-to-figma status
  cast-to-figma inspect [--node-id ID] [--node-url URL] [--depth N] [--scale N] [--no-inline-screenshot]
  cast-to-figma get-variables [--collection NAME] [--query TEXT] [--include-values]
  cast-to-figma get-components [--query TEXT] [--page-id ID] [--all-pages] [--details]
  cast-to-figma get-skill
  cast-to-figma get-memory [--limit N] [--source user|agent|all] [--node-id ID] [--trait-id ID] [--event-id ID] [--detail]
  cast-to-figma clear-agent-corrections
  cast-to-figma update-skill --skill-md-file FILE
  cast-to-figma update-text --node-id ID --text TEXT [--font-size N]
  cast-to-figma get-user-tools
  cast-to-figma add-user-tool --manifest-file FILE --source-file FILE
  cast-to-figma edit-user-tool --tool-id ID [--manifest-file FILE] [--source-file FILE]
  cast-to-figma delete-user-tool --tool-id ID
  cast-to-figma run-user-tool --tool-id ID --node-id ID [--params JSON]
  cast-to-figma run-script --reason "Created 10 frames" --source-file FILE
  cast-to-figma clone-node --node-id ID [--parent-id ID] [--x N] [--y N]
  cast-to-figma clone-layout --from-node-id ID --to-node-id ID
  cast-to-figma clone-traits --to-node-id ID [--from-node-id ID] [--traits fills,typography] [--trait-id ID]
  cast-to-figma exec --tool TOOL [--data JSON]
  cast-to-figma cowork [--instruction TEXT] [--timeout 600] [--wait 3] [--target NODE_ID] [--json] [--agent ID]
  cast-to-figma install-cli-skill --folder {agent_skill_folder}
  cast-to-figma update [--check]

Common options:
  --agent ID       Agent id shown in Figma (default: cli)
  --json           Print raw JSON result
`);
}

/** Parses simple CLI args. */
function parse(argv) {
  const opts = { _: [] };
  for (let i = 0; i < argv.length; i += 1) {
    const arg = argv[i];
    if (!arg.startsWith('--')) {
      opts._.push(arg);
      continue;
    }
    const key = arg.slice(2);
    if (BOOLEAN_FLAGS.has(key)) {
      opts[key] = true;
      continue;
    }
    opts[key] = argv[i + 1];
    i += 1;
  }
  return opts;
}

/** Expands a leading home-directory marker in a CLI path. */
function expandHome(filePath) {
  if (!filePath) return filePath;
  if (filePath === '~') return process.env.HOME || filePath;
  if (filePath.startsWith('~/')) return path.join(process.env.HOME || '', filePath.slice(2));
  return filePath;
}

/** Returns a normalized run-script reason or throws a user-facing validation error. */
function validateRunScriptReason(reason) {
  if (typeof reason !== 'string' || !reason.trim()) {
    throw new Error('run-script requires --reason, max 6 words, e.g. "Created 10 frames"');
  }
  const trimmed = reason.trim().replace(/\s+/g, ' ');
  if (trimmed.length > RUN_SCRIPT_REASON_MAX_CHARS) throw new Error(`run-script --reason is too long (max ${RUN_SCRIPT_REASON_MAX_CHARS} characters)`);
  if (trimmed.split(' ').filter(Boolean).length > RUN_SCRIPT_REASON_MAX_WORDS) throw new Error(`run-script --reason is too long (max ${RUN_SCRIPT_REASON_MAX_WORDS} words)`);
  return trimmed;
}

/** Validates external run-script calls before they reach the Figma plugin. */
function validateRunScriptData(tool, data) {
  if (tool === 'run-script') data.reason = validateRunScriptReason(data.reason);
  if (tool === 'exec' && data?.tool === 'run-script') {
    data.data = data.data || {};
    data.data.reason = validateRunScriptReason(data.data.reason);
  }
}

/** Normalizes a semver-ish string for comparison. */
function normalizeVersion(version) {
  return String(version || '').trim().replace(/^v/i, '');
}

/** Compares two semver-ish strings. */
function compareVersions(a, b) {
  const left = normalizeVersion(a).split(/[.-]/).map((part) => Number(part) || 0);
  const right = normalizeVersion(b).split(/[.-]/).map((part) => Number(part) || 0);
  for (let i = 0; i < Math.max(left.length, right.length); i += 1) {
    if ((left[i] || 0) > (right[i] || 0)) return 1;
    if ((left[i] || 0) < (right[i] || 0)) return -1;
  }
  return 0;
}

/** Fetches JSON from GitHub with a CLI-friendly user agent. */
async function fetchGithubJson(url) {
  const res = await fetch(url, { headers: { 'User-Agent': `cast-to-figma/${PACKAGE.version}` } });
  if (!res.ok) throw new Error(`GitHub request failed: ${res.status}`);
  return res.json();
}

/** Reads the latest Cast version advertised by GitHub releases or main. */
async function latestGithubVersion() {
  try {
    const release = await fetchGithubJson(`https://api.github.com/repos/${GITHUB_REPO}/releases/latest`);
    const version = normalizeVersion(release.tag_name || release.name);
    if (version) return version;
  } catch (_) {}
  try {
    const pkg = await fetchGithubJson(`https://raw.githubusercontent.com/${GITHUB_REPO}/main/package.json`);
    return normalizeVersion(pkg.version);
  } catch (_) {
    const pkg = await fetchGithubJson(`https://raw.githubusercontent.com/${GITHUB_REPO}/master/package.json`);
    return normalizeVersion(pkg.version);
  }
}

/** Updates this git checkout from GitHub when possible. */
async function updateCast(opts) {
  const latest = await latestGithubVersion().catch((error) => ({ error: error.message || String(error) }));
  const latestVersion = typeof latest === 'string' ? latest : undefined;
  const result = {
    label: 'Checked Cast updates',
    currentVersion: PACKAGE.version,
    latestVersion,
    updateAvailable: latestVersion ? compareVersions(PACKAGE.version, latestVersion) < 0 : null,
    repository: `https://github.com/${GITHUB_REPO}`,
  };

  if (opts.check) return result;
  if (!fs.existsSync(path.join(ROOT, '.git'))) {
    result.label = 'Cast update available from GitHub';
    result.command = `npm install -g git+https://github.com/${GITHUB_REPO}.git`;
    result.pluginNote = 'After updating, reload the Cast plugin.';
    return result;
  }

  const pull = spawnSync('git', ['pull', '--ff-only'], { cwd: ROOT, stdio: 'inherit' });
  if (pull.status !== 0) throw new Error('git pull --ff-only failed');
  const install = spawnSync('npm', ['install'], { cwd: ROOT, stdio: 'inherit' });
  if (install.status !== 0) throw new Error('npm install failed');
  const bridgeInstall = spawnSync('npm', ['install', '--omit=dev'], { cwd: path.join(ROOT, 'bridge'), stdio: 'inherit' });
  if (bridgeInstall.status !== 0) throw new Error('bridge npm install failed');

  result.label = 'Updated Cast from GitHub';
  result.pluginNote = 'Reload the Cast plugin.';
  return result;
}

/** Prints a compatibility warning when the connected plugin is stale. */
function warnIfVersionMismatch(status) {
  if (process.env.CAST_DISABLE_VERSION_CHECK === '1' || !status || !status.connected) return;
  const pluginVersion = status.pluginVersion || 'unknown';
  const pluginProtocol = status.pluginProtocolVersion || 'unknown';
  if (status.versionMatch !== false && status.protocolMatch !== false && status.pluginVersion) return;
  console.error(`Cast version warning: CLI ${PACKAGE.version}/protocol ${PROTOCOL_VERSION}, plugin ${pluginVersion}/protocol ${pluginProtocol}.`);
  console.error('Run `cast-to-figma update`, then reload the Cast plugin.');
}

/** Checks the connected plugin version without interrupting the requested command. */
async function checkConnectedVersions() {
  try {
    const res = await fetch(`${BRIDGE}/status`);
    if (res.ok) warnIfVersionMismatch(await res.json());
  } catch (_) {}
}

/** Copies bundled CLI skill files into an agent skill folder. */
function installCliSkill(opts) {
  const agentSkillFolder = path.resolve(expandHome(opts.folder || path.join(process.env.HOME || '.', '.agents', 'skills')));
  const target = path.join(agentSkillFolder, 'cast-to-figma');
  const files = ['SKILL.md', 'README.md', 'LICENSE', path.join('assets', 'cover.png'), path.join('assets', 'scheme.png')];

  fs.mkdirSync(target, { recursive: true });
  for (const relativePath of files) {
    const source = path.join(ROOT, relativePath);
    if (!fs.existsSync(source)) continue;
    const destination = path.join(target, relativePath);
    if (path.resolve(source) === path.resolve(destination)) continue;
    fs.mkdirSync(path.dirname(destination), { recursive: true });
    fs.copyFileSync(source, destination);
  }

  return {
    label: `Installed Cast CLI skill to ${target}`,
    agentSkillFolder,
    target,
    files: files.filter((relativePath) => fs.existsSync(path.join(ROOT, relativePath))),
  };
}

/** Converts CLI options to Cast tool data. */
function buildData(tool, opts) {
  if (tool === 'exec') return { tool: opts.tool, data: opts.data ? JSON.parse(opts.data) : {} };
  if (opts.data) return JSON.parse(opts.data);
  const data = {};
  if (opts['node-id']) data.nodeId = opts['node-id'];
  if (opts['from-node-id']) data.fromNodeId = opts['from-node-id'];
  if (opts['to-node-id']) data.toNodeId = opts['to-node-id'];
  if (opts['node-url']) data.nodeUrl = opts['node-url'];
  if (opts['page-id']) data.pageId = opts['page-id'];
  if (opts.collection) data.collection = opts.collection;
  if (opts.query) data.query = opts.query;
  if (opts.depth) data.depth = Number(opts.depth);
  if (opts.scale) data.scale = Number(opts.scale);
  if (opts.mode) data.mode = opts.mode;
  if (opts.scope) data.scope = opts.scope;
  if (opts.text) data.text = opts.text;
  if (opts['font-size']) data.fontSize = Number(opts['font-size']);
  if (opts.name) data.name = opts.name;
  if (opts.x) data.x = Number(opts.x);
  if (opts.y) data.y = Number(opts.y);
  if (opts.width) data.width = Number(opts.width);
  if (opts.height) data.height = Number(opts.height);
  if (opts.opacity) data.opacity = Number(opts.opacity);
  if (opts.visible) data.visible = opts.visible !== 'false';
  if (opts.rotation) data.rotation = Number(opts.rotation);
  if (opts.index) data.index = Number(opts.index);
  if (opts.parentId || opts['parent-id']) data.parentId = opts.parentId || opts['parent-id'];
  if (opts.type) data.type = opts.type;
  if (opts['include-values']) data.includeValues = true;
  if (opts['include-scopes']) data.includeScopes = true;
  if (opts['include-variants']) data.includeVariants = true;
  if (opts['all-pages']) data.allPages = true;
  if (opts.details) data.details = true;
  if (opts['layout-mode']) data.layoutMode = opts['layout-mode'];
  if (opts['primary-axis-sizing-mode']) data.primaryAxisSizingMode = opts['primary-axis-sizing-mode'];
  if (opts['counter-axis-sizing-mode']) data.counterAxisSizingMode = opts['counter-axis-sizing-mode'];
  if (opts['primary-axis-align-items']) data.primaryAxisAlignItems = opts['primary-axis-align-items'];
  if (opts['counter-axis-align-items']) data.counterAxisAlignItems = opts['counter-axis-align-items'];
  if (opts['padding-top']) data.paddingTop = Number(opts['padding-top']);
  if (opts['padding-right']) data.paddingRight = Number(opts['padding-right']);
  if (opts['padding-bottom']) data.paddingBottom = Number(opts['padding-bottom']);
  if (opts['padding-left']) data.paddingLeft = Number(opts['padding-left']);
  if (opts['item-spacing']) data.itemSpacing = Number(opts['item-spacing']);
  if (opts.source) data.source = opts.source;
  if (opts['source-file']) data.source = fs.readFileSync(opts['source-file'], 'utf8');
  if (opts.reason) data.reason = opts.reason;
  if (opts['tool-id']) data.toolId = opts['tool-id'];
  if (opts.params) data.params = JSON.parse(opts.params);
  if (opts.manifest) data.manifest = JSON.parse(opts.manifest);
  if (opts['manifest-file']) data.manifest = JSON.parse(fs.readFileSync(opts['manifest-file'], 'utf8'));
  if (opts.limit) data.limit = Number(opts.limit);
  if (opts.source) data.source = opts.source;
  if (opts['trait-id']) data.traitId = opts['trait-id'];
  if (opts['trait-ids']) data.traitIds = String(opts['trait-ids']).split(',').map((item) => item.trim()).filter(Boolean);
  if (opts.traits) data.traits = String(opts.traits).split(',').map((item) => item.trim()).filter(Boolean);
  if (opts['event-id']) data.eventId = opts['event-id'];
  if (opts.detail) data.detail = true;
  if (opts.offset) data.offset = Number(opts.offset);
  if (opts['sample-limit']) data.sampleLimit = Number(opts['sample-limit']);
  if (opts['skill-md']) data.skillMd = opts['skill-md'];
  if (opts['skill-md-file']) data.skillMd = fs.readFileSync(opts['skill-md-file'], 'utf8');
  return data;
}

/** Starts bridge when needed. */
function ensure(opts) {
  if (opts['no-ensure']) return;
  spawnSync(ENSURE, { stdio: 'ignore' });
}

/** Calls Cast HTTP API. */
async function call(tool, data, agent) {
  if (tool === 'status') {
    const res = await fetch(`${BRIDGE}/status`);
    const json = await res.json();
    warnIfVersionMismatch(json);
    return json;
  }
  const castTool = tool === 'exec' ? data.tool : tool;
  const castData = tool === 'exec' ? (data.data || {}) : data;
  const res = await fetch(`${BRIDGE}/exec`, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ tool: castTool, agent, data: castData }),
  });
  const json = await res.json().catch(() => ({}));
  if (!res.ok) {
    const detail = json.detail ? ` — ${json.detail}` : '';
    const hint = json.hint ? ` (${json.hint})` : '';
    throw new Error(`${json.error || `Cast request failed: ${res.status}`}${detail}${hint}`);
  }
  return json;
}

/** Returns one-line summary. */
function summary(tool, result) {
  if (tool === 'status') {
    const suffix = result.port ? ` on port ${result.port}` : '';
    return result.connected ? `Cast plugin connected${suffix}` : `Cast plugin not connected${suffix}`;
  }
  if (tool === 'update') {
    if (result.updateAvailable === false) return `Cast is current (${result.currentVersion})`;
    return result.label || 'Checked Cast updates';
  }
  if (result && typeof result.label === 'string') return result.label;
  return TOOL_LABELS.done[tool] || `Ran ${tool}`;
}

/** Returns screenshot artifacts discovered in an inspect result. */
function screenshotArtifacts(result) {
  if (Array.isArray(result.nodes)) {
    return result.nodes
      .map((entry, index) => ({ index, path: entry.screenshotPath, node: entry.node }))
      .filter((entry) => entry.path);
  }
  return result.screenshotPath ? [{ index: 0, path: result.screenshotPath, node: result.node }] : [];
}

/** Builds a rerun hint for smaller inspect screenshots. */
function smallerScreenshotHint(opts) {
  const currentScale = Number(opts.scale || 1);
  const nextScale = Math.max(0.1, Math.round((currentScale * 0.5) * 100) / 100);
  const target = opts['node-id'] ? ` --node-id ${opts['node-id']}` : opts['node-url'] ? ` --node-url ${opts['node-url']}` : '';
  const depth = opts.depth ? ` --depth ${opts.depth}` : '';
  return `cast inspect${target}${depth} --scale ${nextScale}`;
}

/** Attaches inline visual artifact data to inspect results when safe. */
function attachVisualArtifacts(result, opts) {
  const artifacts = screenshotArtifacts(result).map((artifact) => {
    const visual = {
      type: 'image/png',
      path: artifact.path,
      required: true,
      contract: 'VISUAL_CHECK_REQUIRED: inspect this screenshot before making visual edits.',
    };
    try {
      const stat = fs.statSync(artifact.path);
      visual.bytes = stat.size;
      if (!opts['no-inline-screenshot'] && stat.size <= INSPECT_INLINE_LIMIT_BYTES) {
        visual.dataUrl = `data:image/png;base64,${fs.readFileSync(artifact.path).toString('base64')}`;
      } else if (!opts['no-inline-screenshot']) {
        visual.tooLarge = true;
        visual.hint = `Screenshot data is ${stat.size} bytes and may be truncated. Rerun with smaller scale: ${smallerScreenshotHint(opts)}`;
      }
    } catch (error) {
      visual.error = `Unable to read screenshot artifact: ${error.message || String(error)}`;
    }
    return visual;
  });

  if (artifacts.length > 0) result.visualArtifacts = artifacts;
  return result;
}

/** Prints readable result. */
function printHuman(tool, result) {
  console.log(`Cast ${tool}`);
  console.log(`✓ ${summary(tool, result)}`);

  const node = result.node || result.nodes?.[0]?.node || result;
  if (node && node.id && node.name) console.log(`node: ${node.type || 'NODE'} ${node.id} “${node.name}”`);
  if (node && node.width && node.height) console.log(`size: ${Math.round(node.width)} × ${Math.round(node.height)}`);
  const screenshotPath = result.screenshotPath || result.nodes?.[0]?.screenshotPath;
  if (screenshotPath) console.log(`screenshot: ${screenshotPath}`);
  if (tool === 'inspect' && Array.isArray(result.visualArtifacts) && result.visualArtifacts.length > 0) {
    console.log('VISUAL_CHECK_REQUIRED');
    console.log('You must inspect the screenshot before making visual edits.');
    for (const artifact of result.visualArtifacts) {
      console.log('visualArtifact:');
      console.log(`  type: ${artifact.type}`);
      console.log(`  path: ${artifact.path}`);
      if (artifact.bytes) console.log(`  bytes: ${artifact.bytes}`);
      if (artifact.dataUrl) console.log(`  dataUrl: ${artifact.dataUrl}`);
      if (artifact.tooLarge) console.log('VISUAL_ARTIFACT_TOO_LARGE');
      if (artifact.hint) console.log(`  hint: ${artifact.hint}`);
      if (artifact.error) console.log(`  error: ${artifact.error}`);
    }
  }
  if (tool === 'status') {
    console.log(`cli: ${result.cliVersion || PACKAGE.version}`);
    console.log(`bridge: ${result.bridgeVersion || 'unknown'}`);
    console.log(`plugin: ${result.pluginVersion || 'unknown'}`);
    console.log(`protocol: cli ${result.protocolVersion || PROTOCOL_VERSION}, plugin ${result.pluginProtocolVersion || 'unknown'}`);
    if (result.versionMatch === false || result.protocolMatch === false || (result.connected && !result.pluginVersion)) console.log('version: mismatch');
  }
  if (tool === 'update') {
    if (result.latestVersion) console.log(`latest: ${result.latestVersion}`);
    if (result.command) console.log(`command: ${result.command}`);
    if (result.pluginNote) console.log(`plugin: ${result.pluginNote}`);
  }
  if (result.pageName) console.log(`page: ${result.pageName}`);
  if (result.summary && tool === 'get-variables') console.log(`variables: ${result.summary.variableCount} across ${result.summary.collectionCount} collections`);
  if (result.summary && tool === 'get-components') console.log(`components: ${result.summary.componentCount}, sets: ${result.summary.componentSetCount}, pages: ${result.summary.pageCount}`);
  if (tool === 'get-memory' && result.user) {
    const lines = Array.isArray(result.user.summary) ? result.user.summary : [];
    if (lines.length > 0) console.log(`\n${lines.join('\n')}`);
    else if (Array.isArray(result.user.nodes)) console.log(`memory nodes: ${result.user.nodes.map((n) => n.nodeId).join(', ') || '(none)'}`);
  }
  if (Array.isArray(result.pages)) console.log(`pages: ${result.pages.map((p) => p.name || p.pageName).join(', ')}`);
  if (Array.isArray(result.tools)) console.log(`tools: ${result.tools.map((t) => t.id || t.name).join(', ') || '(none)'}`);
  if (result.contextMd) console.log(`\n${result.contextMd}`);
  printRecall(result.recall);
}

/** Prints the auto-attached recall envelope (recent memory + correction summaries). */
function printRecall(recall) {
  if (!recall || typeof recall !== 'object') return;
  const mem = Array.isArray(recall.memory?.summary) ? recall.memory.summary : [];
  const corr = Array.isArray(recall.corrections?.summary) ? recall.corrections.summary : [];
  if (mem.length === 0 && corr.length === 0) return;
  if (mem.length > 0) {
    console.log('\nrecall — recent designer memory:');
    for (const line of mem.slice(-10)) console.log(`  ${line}`);
  }
  if (corr.length > 0) {
    console.log('\nrecall — pending agent corrections:');
    for (const line of corr.slice(-10)) console.log(`  ${line}`);
  }
}

/** Main CLI entrypoint. */
async function main() {
  const opts = parse(process.argv.slice(2));
  const command = opts._[0];
  if (!command || command === 'help' || command === '--help') {
    usage();
    return;
  }
  if (!COMMANDS.has(command)) throw new Error(`Unknown Cast command: ${command}`);
  const castCommand = COMMANDS.get(command);
  if (castCommand === 'cowork') {
    const child = spawnSync(COWORK, process.argv.slice(3), { stdio: 'inherit' });
    process.exit(child.status === null ? 1 : child.status);
  }
  if (command === 'install-cli-skill') {
    const result = installCliSkill(opts);
    if (opts.json) console.log(JSON.stringify(result, null, 2));
    else printHuman(command, result);
    return;
  }
  if (command === 'update') {
    const result = await updateCast(opts);
    if (opts.json) console.log(JSON.stringify(result, null, 2));
    else printHuman(command, result);
    return;
  }
  const data = buildData(castCommand, opts);
  validateRunScriptData(castCommand, data);
  ensure(opts);
  if (castCommand !== 'status') await checkConnectedVersions();
  const result = await call(castCommand, data, opts.agent || 'cli');
  const output = castCommand === 'inspect' ? attachVisualArtifacts(result, opts) : result;
  if (opts.json) console.log(JSON.stringify(output, null, 2));
  else printHuman(castCommand, output);
}

main().catch((error) => {
  console.error(`Cast error: ${error.message || String(error)}`);
  process.exit(1);
});
